# Discord Bot Token (required for message export)
# Create a bot at https://discord.com/developers/applications
# Guide: https://discordpy.readthedocs.io/en/stable/discord.html
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic API Key (optional - enables LLM-powered features)
# Get one at https://console.anthropic.com/
# Without this key, you still get all statistical analysis, just no personality
# reads, roasts, AI-generated awards, or the Oracle chatbot.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (optional, default 5002)
PORT=5002
